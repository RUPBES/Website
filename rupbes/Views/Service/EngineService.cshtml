<!-- Секция 3 - Аттестаты (ИН, ИЗ, СТ) -->
<section id="section-3" class="section certificates">
    <div class="container fade-up">
        <h2>Аттестаты и лицензии</h2>
        <div class="certs-grid">
            @if (Model != null && Model.Any(x => x.IsCertificate == true))
            {
                var certificates = Model.Where(x => x.IsCertificate == true).ToList();
                foreach (var cert in certificates)
                {
                    <!-- Проверяем есть ли изображения у сертификата -->
                    if (cert.Imgs != null && cert.Imgs.Any())
                    {
                        foreach (var img in cert.Imgs)
                        {
                            <div class="cert-card">
                                @if (!string.IsNullOrEmpty(img.src) && (img.src.ToLower().EndsWith(".jpg") ||
                                     img.src.ToLower().EndsWith(".jpeg") ||
                                     img.src.ToLower().EndsWith(".png") ||
                                     img.src.ToLower().EndsWith(".gif")))
                                {
                                    <img src="@img.src" alt="@cert.Name" onclick="openImageModal('@img.src')" style="cursor: pointer;">
                                }
                                else if (!string.IsNullOrEmpty(img.src) && img.src.ToLower().EndsWith(".pdf"))
                                {
                                    <img src="/images/pdf-icon.png" alt="PDF" onclick="openPdfModal('@img.src')" style="cursor: pointer;">
                                    <span class="pdf-badge">PDF</span>
                                }
                                else
                                {
                                    <img src="https://placehold.co/300x400/003366/white?text=@cert.Name" alt="@cert.Name">
                                }
                                <p>@cert.Name</p>
                            </div>
                        }
                    }
                    else
                    {
                        <!-- Если нет изображений, показываем заглушку -->
                        <div class="cert-card">
                            <img src="https://placehold.co/300x400/003366/white?text=@cert.Name" alt="@cert.Name">
                            <p>@cert.Name</p>
                        </div>
                    }
                }
            }
            else
            {
                <div class="col-12">
                    <p style="text-align: center; color: #666;">Нет доступных сертификатов</p>
                </div>
            }
        </div>
        <p style="text-align: center; margin-top: 30px; color: #666;">* Для просмотра полного изображения нажмите на фото</p>
    </div>
</section>

<!-- Секция 4 - Партнеры (Заказчики) -->
<section id="section-4" class="section partners">
    <div class="container fade-up">
        <h2>Наши партнеры и заказчики</h2>
        <div class="partners-grid">
            @if (Model != null && Model.Any(x => x.IsPartner == true))
            {
                var partners = Model.Where(x => x.IsPartner == true).ToList();
                foreach (var partner in partners)
                {
                    var firstImg = partner.Imgs?.FirstOrDefault();
                    var imageUrl = firstImg?.src ?? "https://placehold.co/100x100/003366/white?text=" + partner.Name;
                    var isImage = imageUrl.ToLower().EndsWith(".jpg") ||
                                  imageUrl.ToLower().EndsWith(".jpeg") ||
                                  imageUrl.ToLower().EndsWith(".png") ||
                                  imageUrl.ToLower().EndsWith(".gif");

                    <div class="partner-item">
                        @if (isImage)
                        {
                            <img src="@imageUrl" alt="@partner.Name" onclick="openImageModal('@imageUrl')" style="cursor: pointer;">
                        }
                        else
                        {
                            <img src="@imageUrl" alt="@partner.Name">
                        }
                        <p>@partner.Name</p>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <p style="text-align: center; color: #666;">Нет партнеров</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- Секция 5 - Отзывы -->
<section id="section-5" class="section reviews">
    <div class="container fade-up">
        <h2>Отзывы наших клиентов</h2>
        <div class="reviews-grid">
            @if (Model != null && Model.Any(x => x.IsReview == true))
            {
                var reviews = Model.Where(x => x.IsReview == true).ToList();
                foreach (var review in reviews)
                {
                    var firstImg = review.Imgs?.FirstOrDefault();
                    var imageUrl = firstImg?.src ?? "https://placehold.co/400x300/cccccc/666?text=" + review.Name;
                    var isImage = imageUrl.ToLower().EndsWith(".jpg") ||
                                  imageUrl.ToLower().EndsWith(".jpeg") ||
                                  imageUrl.ToLower().EndsWith(".png") ||
                                  imageUrl.ToLower().EndsWith(".gif");

                    <div class="review-card">
                        @if (isImage)
                        {
                            <img src="@imageUrl" alt="@review.Name" onclick="openImageModal('@imageUrl')" style="cursor: pointer;">
                        }
                        else
                        {
                            <img src="@imageUrl" alt="@review.Name">
                        }
                        @if (!string.IsNullOrEmpty(review.Name))
                        {
                            <p class="review-title">@review.Name</p>
                        }
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <p style="text-align: center; color: #666;">Нет отзывов от клиентов</p>
                </div>
            }
        </div>
    </div>
</section>

